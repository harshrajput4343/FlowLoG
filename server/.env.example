# Supabase PostgreSQL
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Supabase API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

PORT=3001

# Unsplash API
NEXT_PUBLIC_UNSPLASH_KEY=your_unsplash_access_key

# EMAIL SETUP INSTRUCTIONS:
# 1. Use a Gmail account
# 2. Go to Google Account → Security → 2-Step Verification (enable it first)
# 3. Go to Google Account → Security → App Passwords
# 4. Generate a new App Password for "Mail"
# 5. Paste the 16-character app password as EMAIL_PASS with no spaces
# NEVER use your regular Gmail password here
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password
FRONTEND_URL=https://flowlogwork.vercel.app