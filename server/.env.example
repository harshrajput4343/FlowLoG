# Supabase PostgreSQL
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Supabase API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

PORT=3001

# Render.com — set automatically by Render, used for keep-alive pings
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Unsplash API
NEXT_PUBLIC_UNSPLASH_KEY=your_unsplash_access_key

# EMAIL SETUP INSTRUCTIONS:
# 1. Use a Gmail account
# 2. Go to Google Account → Security → 2-Step Verification (enable it first)
# 3. Go to Google Account → Security → App Passwords
# 4. Generate a new App Password for "Mail"
# 5. Paste the 16-character app password as EMAIL_PASS with no spaces
# NEVER use your regular Gmail password here
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password
FRONTEND_URL=https://flowlogwork.vercel.app

# Redis (optional — app works without it)
# Get free Redis from: https://upstash.com
# Format: redis://default:password@host:port
# REDIS_URL=redis://default:xxxx@xxxx.upstash.io:6379

# Razorpay Payment Gateway
# Get from: https://dashboard.razorpay.com
# Use TEST keys during development (rzp_test_...)
# Use LIVE keys after KYC for production (rzp_live_...)
# 1. Sign up at https://razorpay.com
# 2. Complete KYC for live payments
# 3. UPI is supported automatically
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx